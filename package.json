{
  "name": "autosaveit",
  "displayName": "autosaveit",
  "description": "Lightweight auto-save extension for VS Code. Automatically saves files after typing stops with smart debouncing. Zero dependencies, <0.1% CPU usage.",
  "version": "1.0.0",
  "publisher": "AyushPatil",
  "icon": "logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/projectsbyayush/autosaveit"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Other"],
  "keywords": ["auto-save", "autosave", "vscode", "visual studio code", "extension", "productivity", "save", "automatic save", "debounced save", "lightweight", "code editor", "developer tools"],
  "activationEvents": ["*"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autosaveit.toggle",
        "title": "Toggle Auto-save",
        "category": "AutoSave",
        "icon": "$(save)"
      },
      {
        "command": "autosaveit.saveNow",
        "title": "Save All Now",
        "category": "AutoSave"
      }
    ],
    "configuration": {
      "title": "autosaveit",
      "properties": {
        "autosaveit.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable auto-save globally"
        },
        "autosaveit.delay": {
          "type": "number",
          "default": 1000,
          "minimum": 200,
          "maximum": 10000,
          "description": "Milliseconds to wait after typing stops before saving"
        },
        "autosaveit.excludeLanguages": {
          "type": "array",
          "default": [],
          "description": "Language IDs to exclude (e.g., ['markdown', 'jsonc'])"
        },
        "autosaveit.excludePatterns": {
          "type": "array",
          "default": [],
          "description": "Glob patterns of files to exclude from auto-save"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "^16.0.0",
    "typescript": "^4.5.0",
    "vsce": "^2.6.0"
  }
}
